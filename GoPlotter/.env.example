# SFAF Plotter Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database Configuration
DB_HOST=10.0.200.4
DB_PORT=5432
DB_USER=freqman
DB_PASSWORD=your_secure_password_here
DB_NAME=freqnom_DB
DB_SSLMODE=disable

# Optional: Full database URL (overrides individual DB settings if provided)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=disable

# Application Settings
GIN_MODE=release  # Options: debug, release, test
LOG_LEVEL=info    # Options: debug, info, warn, error

# CORS Settings (comma-separated for multiple origins)
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Feature Flags
ENABLE_MCEB_VALIDATION=true
ENABLE_COORDINATE_CACHING=true
