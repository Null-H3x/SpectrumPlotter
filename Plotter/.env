# ============================================================
# SFAF Plotter - Environment Configuration
# Place this file in the Plotter/ directory (alongside main.go)
# ============================================================

# ----------------------------
# DATABASE (required - no defaults)
# ----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=test
DB_PASSWORD=pass
DB_NAME=sfaf_plotter
DB_SSLMODE=disable

# ----------------------------
# SERVER
# ----------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# GIN_MODE options: debug | release | test
# Use "release" in production
GIN_MODE=debug

# LOG_LEVEL options: debug | info | warn | error
LOG_LEVEL=info

# ----------------------------
# CORS
# ----------------------------
# In production, replace * with your actual origin, e.g. https://yourhost.mil
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ----------------------------
# FEATURE FLAGS
# ----------------------------
# Note: these are read and logged at startup but not yet enforced in business logic
ENABLE_MCEB_VALIDATION=true
ENABLE_COORDINATE_CACHING=true
